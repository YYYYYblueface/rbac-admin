# ========== 应用配置 ==========
APP_NAME=RBAC Admin
APP_VERSION=1.0.0
APP_DEBUG=true

# ========== 数据库配置 ==========
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=123456
DB_NAME=rbac_admin

# ========== Redis 配置 ==========
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ========== JWT 配置 ==========
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# ========== 验证码配置 ==========
CAPTCHA_EXPIRE_SECONDS=300

# ========== 限流配置 ==========
RATE_LIMIT_DEFAULT=60/minute