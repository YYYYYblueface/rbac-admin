# ========== App Config ==========
APP_NAME=RBAC Admin
APP_VERSION=1.0.0
APP_DEBUG=true

# ========== Database Config ==========
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=youpassword
DB_NAME=rbac_admin

# ========== Redis Config ==========
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=youpassword
REDIS_DB=0

# ========== JWT Config ==========
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# ========== Captcha Config ==========
CAPTCHA_EXPIRE_SECONDS=300

# ========== Rate Limit Config ==========
RATE_LIMIT_DEFAULT=60/minute
